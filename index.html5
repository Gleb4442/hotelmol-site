<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Roomie Guest - Membership Tiers Mockup</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    "primary": "#1052D5",
                    "charcoal": "#1A1C1E",
                    "surface": "#F8F9FB",
                },
                fontFamily: {
                    "display": ["Manrope", "sans-serif"]
                }
            },
        }
    }
</script>
<style type="text/tailwindcss">
    :root {
        --primary-color: #1052D5;
    }
    body {
        /* Изменяем фон body для презентационного вида */
        background: radial-gradient(circle at 50% 0%, #f1f5f9 0%, #cbd5e1 100%);
    }
    /* Скрытие скроллбара для реалистичности мокапа */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .metallic-bronze {
        background: linear-gradient(135deg, #FDF4F0 0%, #E7D0C5 50%, #C49B85 100%);
    }
    .metallic-silver {
        background: linear-gradient(135deg, #F1F2F4 0%, #E2E4E9 50%, #D1D5DB 100%);
    }
    .metallic-gold {
        background: linear-gradient(135deg, #FFF9E6 0%, #FDE68A 50%, #F59E0B 100%);
    }
    .metallic-platinum {
        background: linear-gradient(135deg, #F8FAFC 0%, #E2E8F0 50%, #94A3B8 100%);
    }
    .glass-nav {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
</style>
</head>
<body class="font-display antialiased flex items-center justify-center min-h-screen py-10">

    <!-- DEVICE MOCKUP WRAPPER -->
    <div class="relative z-10 w-[393px] h-[852px] bg-white rounded-[3.5rem] shadow-[0_35px_60px_-15px_rgba(0,0,0,0.5)] border-[14px] border-slate-900 overflow-hidden" style="transform: translateZ(0);">
        
        <!-- Dynamic Island (Чёлка/вырез камеры) -->
        <div class="absolute top-2 left-1/2 -translate-x-1/2 w-[120px] h-[32px] bg-slate-900 rounded-full z-[100]"></div>

        <!-- APP CONTENT AREA -->
        <div class="h-full w-full overflow-y-auto scrollbar-hide bg-white relative flex flex-col text-charcoal">
            
            <header class="sticky top-0 z-30 bg-white/80 backdrop-blur-md">
                <!-- Увеличен pt-12, чтобы обойти Dynamic Island -->
                <div class="flex items-center justify-between p-3 pt-12">
                    <button class="text-charcoal flex size-8 shrink-0 items-center justify-center rounded-full hover:bg-slate-100 transition-colors">
                        <span class="material-symbols-outlined text-[20px]">arrow_back_ios_new</span>
                    </button>
                    <h1 class="text-primary text-base font-extrabold leading-tight tracking-tight uppercase">Membership Tiers</h1>
                    <button class="text-charcoal flex size-8 shrink-0 items-center justify-center rounded-full hover:bg-slate-100 transition-colors">
                        <span class="material-symbols-outlined text-[20px]">help_outline</span>
                    </button>
                </div>
            </header>

            <main class="flex-1 px-4 pb-28 pt-2 max-w-md mx-auto w-full">
                <section class="mb-6">
                    <p class="text-primary text-[10px] font-extrabold uppercase tracking-[0.15em] mb-3">Current Status</p>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="flex flex-col gap-1 rounded-xl bg-surface border border-slate-100 p-3.5 shadow-sm">
                            <div class="flex items-center gap-1.5 mb-1">
                                <span class="material-symbols-outlined text-primary text-[18px] fill-current">military_tech</span>
                                <span class="text-slate-500 text-[9px] font-bold uppercase tracking-wider">Tier Level</span>
                            </div>
                            <p class="text-charcoal text-xl font-extrabold">Gold</p>
                        </div>
                        <div class="flex flex-col gap-1 rounded-xl bg-surface border border-slate-100 p-3.5 shadow-sm">
                            <div class="flex items-center gap-1.5 mb-1">
                                <span class="material-symbols-outlined text-primary text-[18px]">monetization_on</span>
                                <span class="text-slate-500 text-[9px] font-bold uppercase tracking-wider">Points</span>
                            </div>
                            <p class="text-charcoal text-xl font-extrabold">9,450</p>
                        </div>
                    </div>
                    
                    <div class="mt-4 p-4 rounded-xl bg-primary/[0.03] border border-primary/10">
                        <div class="flex justify-between items-end mb-2">
                            <div>
                                <p class="text-charcoal font-bold text-[13px]">5,550 points to Platinum</p>
                                <p class="text-slate-500 text-[11px] mt-0.5">Keep earning to unlock Platinum perks.</p>
                            </div>
                            <span class="text-primary font-extrabold text-[13px]">63%</span>
                        </div>
                        <div class="h-2 w-full bg-slate-100 rounded-full overflow-hidden">
                            <div class="h-full bg-primary w-[63%] rounded-full shadow-[0_0_10px_rgba(16,82,213,0.3)]"></div>
                        </div>
                    </div>
                </section>

                <h2 class="text-charcoal text-lg font-extrabold mb-4 tracking-tight">Tier Roadmap</h2>
                <div class="flex flex-col gap-4">
                    
                    <!-- Bronze Tier -->
                    <div class="relative overflow-hidden rounded-2xl metallic-bronze shadow-sm">
                        <div class="p-4">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <span class="inline-block px-2 py-0.5 rounded-full bg-white/40 text-orange-900 text-[8px] font-black uppercase tracking-widest mb-2 border border-white/50">Level 01</span>
                                    <h3 class="text-orange-950 text-xl font-black">Bronze</h3>
                                </div>
                                <div class="flex items-center justify-center size-7 rounded-full bg-emerald-500 text-white shadow-md">
                                    <span class="material-symbols-outlined text-[16px] font-bold">check</span>
                                </div>
                            </div>
                            <div class="space-y-1.5 mb-4">
                                <div class="flex items-center gap-2 text-orange-900">
                                    <span class="material-symbols-outlined text-[18px]">wifi</span>
                                    <span class="text-[13px] font-semibold">Standard Free Wi-Fi</span>
                                </div>
                                <div class="flex items-center gap-2 text-orange-900">
                                    <span class="material-symbols-outlined text-[18px]">local_activity</span>
                                    <span class="text-[13px] font-semibold">Member-Only Rates</span>
                                </div>
                            </div>
                            <div class="pt-3 border-t border-orange-950/10 flex justify-between items-center">
                                <span class="text-orange-900/60 text-[9px] font-black uppercase">0 - 2,500 pts</span>
                                <span class="text-emerald-700 text-[9px] font-black uppercase">Earned</span>
                            </div>
                        </div>
                    </div>

                    <!-- Silver Tier -->
                    <div class="relative overflow-hidden rounded-2xl metallic-silver shadow-sm">
                        <div class="p-4">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <span class="inline-block px-2 py-0.5 rounded-full bg-white/40 text-slate-700 text-[8px] font-black uppercase tracking-widest mb-2 border border-white/50">Level 02</span>
                                    <h3 class="text-slate-900 text-xl font-black">Silver</h3>
                                </div>
                                <div class="flex items-center justify-center size-7 rounded-full bg-emerald-500 text-white shadow-md">
                                    <span class="material-symbols-outlined text-[16px] font-bold">check</span>
                                </div>
                            </div>
                            <div class="space-y-1.5 mb-4">
                                <div class="flex items-center gap-2 text-slate-700">
                                    <span class="material-symbols-outlined text-[18px] font-bold">add_circle</span>
                                    <span class="text-[13px] font-bold">All Bronze Benefits</span>
                                </div>
                                <div class="flex items-center gap-2 text-slate-700">
                                    <span class="material-symbols-outlined text-[18px]">speed</span>
                                    <span class="text-[13px] font-semibold">High-Speed Wi-Fi Upgrade</span>
                                </div>
                                <div class="flex items-center gap-2 text-slate-700">
                                    <span class="material-symbols-outlined text-[18px]">local_bar</span>
                                    <span class="text-[13px] font-semibold">Welcome Drink</span>
                                </div>
                            </div>
                            <div class="pt-3 border-t border-slate-900/10 flex justify-between items-center">
                                <span class="text-slate-600 text-[9px] font-black uppercase">2,500 - 7,500 pts</span>
                                <span class="text-emerald-700 text-[9px] font-black uppercase">Earned</span>
                            </div>
                        </div>
                    </div>

                    <!-- Gold Tier (Active) -->
                    <div class="relative overflow-hidden rounded-2xl metallic-gold shadow-md ring-2 ring-amber-400 ring-offset-2 ring-offset-white">
                        <div class="relative z-10 p-4">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <span class="inline-block px-2 py-0.5 rounded-full bg-white/70 text-amber-900 text-[8px] font-black uppercase tracking-widest mb-2 border border-white/80">Active Now</span>
                                    <h3 class="text-amber-950 text-2xl font-black">Gold</h3>
                                </div>
                            </div>
                            <div class="space-y-1.5 mb-4">
                                <div class="flex items-center gap-2 text-amber-950">
                                    <span class="material-symbols-outlined text-[18px] font-bold">add_circle</span>
                                    <span class="text-[13px] font-bold">All Silver Benefits</span>
                                </div>
                                <div class="flex items-center gap-2 text-amber-950">
                                    <span class="material-symbols-outlined text-[18px]">update</span>
                                    <span class="text-[13px] font-semibold">Late Checkout (2 PM)</span>
                                </div>
                                <div class="flex items-center gap-2 text-amber-950">
                                    <span class="material-symbols-outlined text-[18px]">restaurant</span>
                                    <span class="text-[13px] font-semibold">Daily Continental Breakfast</span>
                                </div>
                            </div>
                            <div class="pt-3 border-t border-amber-950/10 flex justify-between items-center">
                                <span class="text-amber-900 text-[9px] font-black uppercase">7,500 - 15,000 pts</span>
                                <span class="text-amber-900 text-[9px] font-black uppercase">Current</span>
                            </div>
                        </div>
                    </div>

                    <!-- Platinum Tier -->
                    <div class="relative overflow-hidden rounded-2xl metallic-platinum shadow-sm opacity-90">
                        <div class="p-4">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <span class="inline-block px-2 py-0.5 rounded-full bg-white/40 text-slate-600 text-[8px] font-black uppercase tracking-widest mb-2">Level 04</span>
                                    <h3 class="text-slate-800 text-xl font-black">Platinum</h3>
                                </div>
                                <div class="flex items-center justify-center size-7 rounded-full bg-white/50 text-slate-500">
                                    <span class="material-symbols-outlined text-[16px]">lock</span>
                                </div>
                            </div>
                            <div class="space-y-1.5 mb-4">
                                <div class="flex items-center gap-2 text-slate-700">
                                    <span class="material-symbols-outlined text-[18px] font-bold">add_circle</span>
                                    <span class="text-[13px] font-bold">All Gold Benefits</span>
                                </div>
                                <div class="flex items-center gap-2 text-slate-700">
                                    <span class="material-symbols-outlined text-[18px]">hotel_class</span>
                                    <span class="text-[13px] font-semibold">Priority Room Upgrades</span>
                                </div>
                                <div class="flex items-center gap-2 text-slate-700">
                                    <span class="material-symbols-outlined text-[18px]">spa</span>
                                    <span class="text-[13px] font-semibold">Club Lounge Access</span>
                                </div>
                            </div>
                            <div class="pt-3 border-t border-slate-900/10 flex justify-between items-center">
                                <span class="text-slate-600 text-[9px] font-black uppercase">15,000 - 30,000 pts</span>
                                <span class="text-slate-500 text-[9px] font-black uppercase tracking-tighter">5,550 pts away</span>
                            </div>
                        </div>
                    </div>

                </div>
            </main>
        </div> <!-- Закрываем контейнер контента (со скроллом) здесь -->

        <!-- Фиксированное меню (перенесено на уровень экрана мокапа) -->
        <div class="absolute bottom-6 left-0 right-0 z-50 flex justify-center px-5 pointer-events-none">
            <nav class="pointer-events-auto flex items-center justify-around gap-1 rounded-full glass-nav px-1.5 py-1.5 shadow-[0_8px_30px_rgba(0,0,0,0.12)] border border-white/20 w-full max-w-sm">
                <a class="flex flex-1 flex-col items-center justify-center gap-0.5 p-1.5 rounded-full hover:bg-primary/5 transition-colors group" href="#">
                    <span class="material-symbols-outlined text-slate-400 group-hover:text-primary transition-colors text-[22px]">home</span>
                    <span class="text-[8px] font-extrabold uppercase tracking-tighter text-slate-400 group-hover:text-primary transition-colors">Home</span>
                </a>
                <a class="flex flex-1 flex-col items-center justify-center gap-0.5 p-1.5 rounded-full hover:bg-primary/5 transition-colors group" href="#">
                    <span class="material-symbols-outlined text-slate-400 group-hover:text-primary transition-colors text-[22px]">room_service</span>
                    <span class="text-[8px] font-extrabold uppercase tracking-tighter text-slate-400 group-hover:text-primary transition-colors">Services</span>
                </a>
                <a class="flex flex-1 flex-col items-center justify-center gap-0.5 p-1.5 rounded-full hover:bg-primary/5 transition-colors group" href="#">
                    <span class="material-symbols-outlined text-slate-400 group-hover:text-primary transition-colors text-[22px]">receipt_long</span>
                    <span class="text-[8px] font-extrabold uppercase tracking-tighter text-slate-400 group-hover:text-primary transition-colors">Orders</span>
                </a>
                <a class="flex flex-1 flex-col items-center justify-center gap-0.5 p-1.5 rounded-full bg-primary shadow-md text-white" href="#">
                    <span class="material-symbols-outlined text-[22px] fill-current">person</span>
                    <span class="text-[8px] font-extrabold uppercase tracking-tighter">Account</span>
                </a>
            </nav>
        </div>
        
    </div>

</body></html>